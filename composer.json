{
    "name": "artempronin/wp-migrate-safe",
    "description": "Reliable WordPress backup/restore plugin with .wpress format support",
    "type": "wordpress-plugin",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "WpMigrateSafe\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WpMigrateSafe\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
